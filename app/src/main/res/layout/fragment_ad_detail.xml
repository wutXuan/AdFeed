<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".ui.detail.AdDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="260dp">

            <ImageView
                android:id="@+id/image_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E7EBF2"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <androidx.media3.ui.PlayerView
                android:id="@+id/player_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:show_buffering="when_playing"
                app:use_controller="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_detail_mute"
                android:layout_width="88dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="14dp"
                android:text="静音"
                android:textSize="12sp"
                android:visibility="gone"
                app:cornerRadius="20dp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/text_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_blue"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="PulseRun" />

            <TextView
                android:id="@+id/text_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/ink_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="晨跑也能像开盲盒" />

            <TextView
                android:id="@+id/text_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/ink_secondary"
                android:textSize="15sp"
                tools:text="AI 生成的详情摘要。" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:singleLine="false" />

            <TextView
                android:id="@+id/text_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/chip_bg"
                android:padding="12dp"
                android:textColor="@color/ink_primary"
                android:textSize="14sp"
                tools:text="AI 推荐理由。" />

            <TextView
                android:id="@+id/text_playful"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/accent_coral"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="不硬广文案。" />

            <TextView
                android:id="@+id/text_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/ink_primary"
                android:textSize="15sp"
                tools:text="广告详情描述。" />

            <TextView
                android:id="@+id/text_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/ink_secondary"
                android:textSize="13sp"
                tools:text="曝光 12 · 点击 2 · 点赞 99" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_like"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="赞"
                    app:cornerRadius="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_collect"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="收藏"
                    app:cornerRadius="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_share"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="分享"
                    app:cornerRadius="6dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
